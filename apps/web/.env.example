# ════════════════════════════════════════════════════════
#  apps/web/.env.example — NEWGAME Web
#  Copy ke .env.local dan isi dengan nilai asli.
#  JANGAN commit .env.local ke git!
# ════════════════════════════════════════════════════════

# Firebase Web SDK — ambil dari Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# PostHog Analytics (opsional)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
