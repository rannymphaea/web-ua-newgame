generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(cuid())
  // Better Auth fields (wajib)
  name           String
  email          String         @unique
  emailVerified  Boolean        @default(false) @map("email_verified")
  image          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Field tambahan NEWGAME
  firebaseUid    String?        @unique @map("firebase_uid")  // legacy, hapus setelah migrasi
  displayName    String?        @map("display_name")
  photoUrl       String?        @map("photo_url")
  role           String         @default("member")             // superadmin,admin,member,npc,glory
  pillar         String?                                       // Game Logic/Design/Sound
  division       String?                                       // divisi lama
  memberId       String?        @unique @map("member_id")      // NG11020038PG
  xpCache        Int            @default(0) @map("xp_cache")
  level          Int            @default(1)
  streak         Int            @default(0)
  attendanceCount Int           @default(0) @map("attendance_count")
  status         String         @default("active")             // active,suspended,inactive
  nim            String?        @unique
  angkatan       Int?
  isActive       Boolean        @default(true) @map("is_active")
  lastLoginAt    DateTime?      @map("last_login_at")

  // Relasi
  sessions       Session[]
  accounts       Account[]
  activities     Activity[]
  attendances    Attendance[]
  authoredNews   NewsArticle[]  @relation("ArticleAuthor")
  notifications  Notification[]
  profile        UserProfile?
  xpHistory      XpHistory[]
  member         Member?        // diisi setelah anggota registrasi

  @@map("users")
}

model UserProfile {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  bio        String?
  github     String?
  linkedin   String?
  instagram  String?
  skills     String[]
  pillar     String?
  currentExp Int      @default(0) @map("current_exp")
  totalExp   Int      @default(0) @map("total_exp")
  level      Int      @default(1)
  badgeIds   String[] @map("badge_ids")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// Better Auth — Session
model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Better Auth — OAuth Account (Google, dsb)
model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")       // sub dari Google
  providerId            String    @map("provider_id")     // "google", "credential"
  accessToken           String?   @map("access_token")    @db.Text
  refreshToken          String?   @map("refresh_token")   @db.Text
  idToken               String?   @map("id_token")        @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?   @db.Text                // bcrypt hash untuk credential provider
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Better Auth — Email verification & password reset tokens
model Verification {
  id         String    @id @default(cuid())
  identifier String                                       // email
  value      String                                       // token
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("verifications")
}


model NewsArticle {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  coverUrl    String?    @map("cover_url")
  authorId    String     @map("author_id")
  status      NewsStatus @default(DRAFT)
  tags        String[]
  publishedAt DateTime?  @map("published_at")
  viewCount   Int        @default(0) @map("view_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  author      User       @relation("ArticleAuthor", fields: [authorId], references: [id])

  @@map("news_articles")
}

model Event {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        EventType
  location    String?
  startAt     DateTime     @map("start_at")
  endAt       DateTime?    @map("end_at")
  isRequired  Boolean      @default(false) @map("is_required")
  maxAttendee Int?         @map("max_attendee")
  qrCode      String?      @unique @map("qr_code")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  attendances Attendance[]

  @@map("events")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  eventId   String           @map("event_id")
  status    AttendanceStatus @default(PRESENT)
  note      String?
  checkedAt DateTime         @default(now()) @map("checked_at")
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("attendances")
}

model XpHistory {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  amount     Int
  reason     String
  sourceType String   @map("source_type")
  sourceId   String?  @map("source_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_history")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String
  title       String
  description String?
  expGained   Int      @default(0) @map("exp_gained")
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Roles diubah ke String field di User agar fleksibel (tidak perlu enum per perubahan role)
// Nilai valid: superadmin, admin, moderator, member, npc, glory, glory_lead

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED
  ABSENT
}

enum EventType {
  WEEKLY_STUDY
  MANDATORY
  OPTIONAL
  COMPETITION
  INTERNAL
}

// ── Member registry ───────────────────────────────────────────────────────────
// Tabel ini adalah daftar resmi 125 anggota NEWGAME.
// Berdiri sendiri dari User — anggota baru register dengan cara verifikasi
// memberId + tempPassword, lalu akun User dibuat dan dihubungkan via userId.

enum MemberStatus {
  ACTIVE
  AFK
  RESIGN
  GLORY
  NPC
}

enum MemberPillar {
  GAME_LOGIC
  GAME_DESIGN
  GAME_SOUND
}

enum MemberGeneration {
  GEN_1
  GEN_2
}

model Member {
  id           String           @id @default(cuid())
  memberId     String           @unique @map("member_id")   // format: NG11001001GL
  memberNo     Int              @map("member_no")            // nomor urut
  name         String
  pillar       MemberPillar
  generation   MemberGeneration
  team         String           @default("")
  status       MemberStatus     @default(ACTIVE)

  // Auth — password sementara yang di-hash bcrypt
  // Digunakan saat registrasi pertama kali
  tempPassword String           @map("temp_password")       // bcrypt hash
  isRegistered Boolean          @default(false) @map("is_registered")
  registeredAt DateTime?        @map("registered_at")

  // XP cache — disinkron dari XpHistory
  xpCache      Int              @default(0) @map("xp_cache")
  level        Int              @default(1)

  // Relasi ke User (diisi setelah register)
  userId       String?          @unique @map("user_id")
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([pillar])
  @@index([generation])
  @@index([status])
  @@index([memberId])
  @@map("members")
}
