# ════════════════════════════════════════════════════════
#  .gitignore — NEWGAME Monorepo
#  Update: 5 Juni 2026 — perkuat proteksi credential
# ════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/
.yarn-integrity

# ── Build output ──────────────────────────────────────
dist/
.next/
out/
build/
*.tsbuildinfo
.turbo/

# ── Environment & SECRETS — JANGAN PERNAH COMMIT ──────
.env
.env.*
*.local
.env.local
.env.production
.env.development
.env.staging
.env.test
!.env.example        # .env.example boleh — berisi placeholder saja

# ── Firebase — service account key adalah rahasia ─────
.firebase/
serviceAccountKey.json
serviceAccountKey*.json
**/serviceAccountKey*.json
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── Cloudinary / Storage ──────────────────────────────
.uploads/

# ── Credential & sensitive docs ───────────────────────
MEMBER_CREDENTIALS.md

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
.vs/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ── OS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
ehthumbs.db

# ── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ── Runtime ───────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
.nyc_output/
coverage/
*.lcov
.grunt/
lib-cov/
jspm_packages/

# ── Vercel ────────────────────────────────────────────
.vercel/

# ── Prisma ────────────────────────────────────────────
# generated client — jangan commit
apps/api/src/generated/

# ── Asset besar ───────────────────────────────────────
/assets/
*.optimized.png
*.optimized.webp

# ── Backup / temp dev ─────────────────────────────────
backup-*/
trae-test/
claude.md
workflow.md
afbof.md
full_project.txt
index.html
storage.rules

# ── Flutter submodule (tracked as embedded repo) ──────
# Gunakan: git submodule add jika ingin track dengan benar
flutter/

# ── Misc internal ─────────────────────────────────────
security/internal/
