# ════════════════════════════════════════════════════════
#  .vercelignore — NEWGAME
#  File yang TIDAK perlu di-upload ke Vercel.
#  Vercel hanya perlu apps/web/ untuk deploy Next.js.
#  Referensi: https://vercel.com/docs/deployments/ignoring-source-files
# ════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/

# ── Build outputs ─────────────────────────────────────
.next/
out/
build/
dist/
apps/web/.next/

# ── Backend API — deploy terpisah, BUKAN di Vercel ────
apps/api/

# ── Tools developer ───────────────────────────────────
tools/
flutter/
trae-test/
scripts/
security/

# ── Environment & credentials ─────────────────────────
.env
.env.*
*.local
.env.local
.env.production
.env.development
serviceAccountKey.json
serviceAccountKey*.json
MEMBER_CREDENTIALS.md

# ── Firebase & cloud storage ──────────────────────────
.firebase/
.uploads/
storage.rules

# ── Assets besar (> 1MB, tidak perlu di-upload) ───────
/assets/
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.mp3
*.wav
*.ogg
*.ttf
*.woff
*.woff2
# Kecuali yang di dalam apps/web/public (dihandle Vercel otomatis)
!apps/web/public/**

# ── Docs internal (bukan source code) ─────────────────
MEMBER_REGISTRATION.md
ACCOUNT_GUIDE.md
LAPORAN.md
DEVELOPER_GUIDE.md
FLUTTER_ANDROID_SETUP.md
ANNOUNCEMENT.md
SECURITY.md
DOCS.md
CHANGELOG.md
TODO.md
LICENSE
index.html

# ── IDE & OS ──────────────────────────────────────────
.vscode/
.idea/
.vs/
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Vercel internal ───────────────────────────────────
.vercel/
vercel.json.bak

# ── Lock files (Vercel tidak butuh ini saat deploy) ────
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Misc ──────────────────────────────────────────────
backup-*/
*.swp
*.swo
*.optimized.png
*.optimized.webp
claude.md
workflow.md
afbof.md
full_project.txt
